mov 0x1000 -> r32s
mov r32s -> r32bp

main:
    push 0x5000
    push $text
    call $memcpy
    stp

memcpy:
    lod r32s -> r32a
    lod r32s(4) -> r32e
    lod r32s(8) -> r32f
    xor r32a -> r32a
    xor r32b -> r32b
loop:
    lod r32e -> r32a
    and 0xFF -> r32a
    cnd r8b == r8a
    goc $done

    str r8a -> r32f
    add 1 -> r32e
    add 1 -> r32f
    go $loop
done:
    ret
    

text:
=ascii "Hello, World"
=single 0
value:
=quad 0x1234DEAD
saved_text:
