=region text
printf:
    push rp
    mov rs -> rp
    mov 3 -> ra
    int 0x20
    mov rp -> rs
    pop rp
    ret

print:
    push rp
    mov rs -> rp
    lod rp(8) -> ra
    pnt ra
    xor ra -> ra
    pop rp
    ret

println:
    push rp
    mov rs -> rp
    lod rp(8) -> ra
    push ra
    call $print
    add 4 -> rs
    pct 10
    pop rp
    ret

printc:
    push rp
    mov rs -> rp

    lods rp(8) -> ra
    pct ra

    mov rp -> rs
    pop rp
    ret
